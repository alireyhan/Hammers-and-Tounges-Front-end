{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://developer.hashverx.com:8001/api/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "http://developer.hashverx.com:8001/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
